<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane maxHeight="-Infinity" maxWidth="-Infinity"
            minHeight="-Infinity" minWidth="-Infinity"
            prefHeight="520.0" prefWidth="760.0"
            stylesheets="@place-ships-style.css"
            styleClass="placement-root, placement-clean"
            xmlns="http://javafx.com/javafx/25"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.examplez.demo.controller.PlacementController">

    <top>
        <VBox alignment="CENTER" spacing="3.0" styleClass="mission-header"
              BorderPane.alignment="CENTER">
            <padding>
                <Insets top="16.0" right="24.0" bottom="14.0" left="24.0" />
            </padding>

            <HBox alignment="CENTER" spacing="9.0">
                <Region prefWidth="42.0" prefHeight="1.0" styleClass="header-line" />
                <Label text="FLEET DEPLOYMENT // PHASE 02" styleClass="eyebrow" />
                <Region prefWidth="42.0" prefHeight="1.0" styleClass="header-line-reversed" />
            </HBox>

            <Label text="BATTLESHIP" styleClass="screen-title" />
            <Label text="Place your fleet before starting the match"
                   styleClass="screen-subtitle" />
        </VBox>
    </top>

    <center>
        <VBox alignment="CENTER" spacing="7.0" styleClass="board-zone"
              BorderPane.alignment="CENTER">
            <padding>
                <Insets top="10.0" right="16.0" bottom="12.0" left="16.0" />
            </padding>

            <HBox alignment="CENTER_LEFT" maxWidth="420.0" spacing="7.0"
                  styleClass="board-caption">
                <Region prefWidth="7.0" prefHeight="7.0"
                        minWidth="7.0" minHeight="7.0"
                        maxWidth="7.0" maxHeight="7.0"
                        styleClass="board-status-dot" />
                <Label text="DEPLOYMENT ZONE" styleClass="board-caption-title" />
                <Region HBox.hgrow="ALWAYS" />
                <Label text="TACTICAL GRID" styleClass="board-caption-meta" />
            </HBox>

            <GridPane fx:id="boardGrid" alignment="CENTER"
                      hgap="3.0" vgap="3.0"
                      maxWidth="420.0" maxHeight="420.0"
                      styleClass="board-grid" />

            <Label text="DRAG A SHIP OVER THE GRID TO PREVIEW IT"
                   styleClass="board-hint" />
        </VBox>
    </center>

    <right>
        <VBox prefWidth="400.0" spacing="11.0" styleClass="fleet-panel"
              BorderPane.alignment="CENTER">
            <padding>
                <Insets top="18.0" right="17.0" bottom="18.0" left="17.0" />
            </padding>

            <HBox alignment="CENTER_LEFT" spacing="7.0">
                <Region prefWidth="5.0" prefHeight="22.0" styleClass="section-accent" />
                <VBox spacing="0.0">
                    <Label text="PENDING FLEET" styleClass="panel-title" />
                    <Label text="SELECT AND DEPLOY" styleClass="panel-kicker" />
                </VBox>
                <Region HBox.hgrow="ALWAYS" />
                <Label text="READY" styleClass="ready-badge" />
            </HBox>

            <ListView id="ShipListView" fx:id="pendingShipsListView"
                      prefHeight="255.0" prefWidth="184.0"
                      VBox.vgrow="ALWAYS"
                      styleClass="ship-list" />

            <HBox alignment="CENTER_LEFT" spacing="7.0" styleClass="orientation-status">
                <Label text="ORIENTATION" styleClass="orientation-label" />
                <Region HBox.hgrow="ALWAYS" />
                <Label text="↔" styleClass="orientation-icon" />
                <Label text="CHANGE" styleClass="orientation-value" />
            </HBox>

            <VBox spacing="8.0">
                <Button fx:id="rotateButton"
                        maxWidth="Infinity"
                        prefHeight="39.0"
                        mnemonicParsing="false"
                        onAction="#onRotateButton"
                        text="ROTATE SHIP"
                        styleClass="action-button, rotate-button" />

                <Button fx:id="startMatchButton"
                        maxWidth="Infinity"
                        prefHeight="45.0"
                        mnemonicParsing="false"
                        onAction="#onStartMatchButton"
                        text="START MATCH"
                        styleClass="action-button, start-match-button" />
            </VBox>
        </VBox>
    </right>
</BorderPane>