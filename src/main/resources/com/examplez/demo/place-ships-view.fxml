<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane maxHeight="-Infinity" maxWidth="-Infinity"
            minHeight="-Infinity" minWidth="-Infinity"
            prefHeight="720.0" prefWidth="1100.0"
            styleClass="placement-root, placement-space"
            stylesheets="@place-ships-style.css"
            xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.examplez.demo.controller.PlacementController">

    <top>
        <VBox alignment="CENTER" spacing="4.0"
              styleClass="mission-header"
              BorderPane.alignment="CENTER">
            <padding>
                <Insets bottom="15.0" left="24.0" right="24.0" top="17.0" />
            </padding>

            <HBox alignment="CENTER" spacing="11.0">
                <Region prefHeight="2.0" prefWidth="52.0"
                        styleClass="header-line" />
                <Label styleClass="eyebrow"
                       text="FLEET DEPLOYMENT // PHASE 02" />
                <Region prefHeight="2.0" prefWidth="52.0"
                        styleClass="header-line-reversed" />
            </HBox>

            <Label styleClass="screen-title" text="BATTLESHIP" />
            <Label styleClass="screen-subtitle"
                   text="Place your fleet before starting the match" />
            <Label fx:id="commanderLabel" styleClass="commander-context" text="COMMANDER: READY // DEPLOY YOUR FLEET" />
        </VBox>
    </top>

    <center>
        <VBox alignment="CENTER" spacing="8.0"
              styleClass="board-zone"
              BorderPane.alignment="CENTER">
            <padding>
                <Insets bottom="13.0" left="16.0"
                        right="16.0" top="12.0" />
            </padding>

            <HBox alignment="CENTER_LEFT"
                  maxWidth="548.0"
                  spacing="8.0"
                  styleClass="board-caption">

                <Region maxHeight="9.0" maxWidth="9.0"
                        minHeight="9.0" minWidth="9.0"
                        prefHeight="9.0" prefWidth="9.0"
                        styleClass="board-status-dot" />

                <Label styleClass="board-caption-title"
                       text="DEPLOYMENT ZONE" />

                <Region HBox.hgrow="ALWAYS" />

                <Label styleClass="board-caption-meta"
                       text="TACTICAL GRID // 10 × 10" />
            </HBox>

            <GridPane fx:id="boardGrid"
                      alignment="CENTER"
                      hgap="3.0" vgap="3.0"
                      maxHeight="548.0"
                      maxWidth="548.0"
                      styleClass="board-grid" />

            <Label styleClass="board-hint"
                   text="DRAG A SHIP OVER THE GRID TO PREVIEW ITS POSITION" />
        </VBox>
    </center>

    <right>
        <VBox prefHeight="528.0"
              prefWidth="500.0"
              spacing="12.0"
              styleClass="fleet-panel"
              BorderPane.alignment="CENTER">
            <padding>
                <Insets bottom="19.0" left="18.0"
                        right="18.0" top="19.0" />
            </padding>

            <HBox alignment="CENTER_LEFT" spacing="9.0">
                <Region prefHeight="29.0"
                        prefWidth="5.0"
                        styleClass="section-accent" />

                <VBox spacing="1.0">
                    <Label styleClass="panel-title"
                           text="PENDING FLEET" />
                    <Label styleClass="panel-kicker"
                           text="SELECT AND DEPLOY" />
                </VBox>

                <Region HBox.hgrow="ALWAYS" />

                <Label styleClass="ready-badge" text="READY" />
            </HBox>

            <ListView id="ShipListView"
                      fx:id="pendingShipsListView"
                      prefHeight="360.0"
                      prefWidth="464.0"
                      styleClass="ship-list"
                      VBox.vgrow="ALWAYS" />

            <HBox alignment="CENTER_LEFT"
                  spacing="8.0"
                  styleClass="orientation-status">

                <Label styleClass="orientation-label"
                       text="ORIENTATION" />

                <Region HBox.hgrow="ALWAYS" />

                <Label fx:id="orientationLabel"
                       styleClass="orientation-icon"
                       text="↔" />

                <Label styleClass="orientation-value"
                       text="CHANGE" />
            </HBox>

            <VBox spacing="9.0">
                <Button fx:id="rotateButton"
                        maxWidth="Infinity"
                        mnemonicParsing="false"
                        onAction="#onRotateButton"
                        prefHeight="46.0"
                        styleClass="action-button, rotate-button"
                        text="ROTATE SHIP" />

                <Button fx:id="startMatchButton"
                        maxWidth="Infinity"
                        mnemonicParsing="false"
                        onAction="#onStartMatchButton"
                        prefHeight="54.0"
                        styleClass="action-button, start-match-button"
                        text="START MATCH" />
            </VBox>
        </VBox>
    </right>
</BorderPane>
