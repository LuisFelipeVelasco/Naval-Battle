<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<BorderPane maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity"
            prefHeight="520.0" prefWidth="760.0"
            style="-fx-background-color: #0b2545;"
            xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="Controller.PlacementController">

    <top>
        <VBox alignment="CENTER" spacing="4.0" BorderPane.alignment="CENTER">
            <padding>
                <Insets bottom="16.0" top="20.0" />
            </padding>
            <Label text="BATALLA NAVAL" textFill="WHITE">
                <font>
                    <javafx.scene.text.Font name="System Bold" size="26.0" />
                </font>
            </Label>
            <Label text="Coloca tu flota antes de iniciar la partida" textFill="#9fb8d9">
                <font>
                    <javafx.scene.text.Font size="13.0" />
                </font>
            </Label>
        </VBox>
    </top>

    <center>
        <VBox alignment="CENTER" BorderPane.alignment="CENTER">
            <GridPane fx:id="boardGrid" alignment="CENTER" hgap="2.0" vgap="2.0"
                      style="-fx-background-color: #123a63; -fx-background-radius: 8; -fx-padding: 10;">
            </GridPane>
        </VBox>
    </center>

    <right>
        <VBox prefWidth="220.0" spacing="14.0" style="-fx-background-color: #123a63;" BorderPane.alignment="CENTER">
            <padding>
                <Insets bottom="20.0" left="18.0" right="18.0" top="24.0" />
            </padding>

            <Label text="Flota pendiente" textFill="WHITE">
                <font>
                    <javafx.scene.text.Font name="System Bold" size="15.0" />
                </font>
            </Label>

            <ListView id="ShipListView" fx:id="pendingShipsListView" prefHeight="300.0" prefWidth="184.0"
                      style="-fx-background-color: #0b2545; -fx-control-inner-background: #0b2545; -fx-text-fill: white;" />

            <VBox spacing="10.0">
                <Button fx:id="rotateButton" maxWidth="Infinity" mnemonicParsing="false" onAction="#onRotateButton"
                        style="-fx-background-color: #1d5b91; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 6;"
                        text="Rotar barco" />

                <Button fx:id="startMatchButton" maxWidth="Infinity" mnemonicParsing="false" onAction="#onStartMatchButton"
                        style="-fx-background-color: #2e9e4d; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 6;"
                        text="Iniciar partida" />
            </VBox>
        </VBox>
    </right>

</BorderPane>
