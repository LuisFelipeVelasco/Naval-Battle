<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<StackPane minHeight="560.0" minWidth="760.0" prefHeight="720.0" prefWidth="1100.0" styleClass="screen-root" stylesheets="@start-view.css" xmlns="http://javafx.com/javafx/23.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.examplez.demo.controller.StartController">

    <!-- Darkens the image edges without blocking mouse interaction. -->
    <Region mouseTransparent="true" styleClass="space-vignette" />

    <BorderPane maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308" prefHeight="607.0" prefWidth="1015.0" styleClass="screen-shell">

        <top>
            <HBox alignment="CENTER_LEFT" spacing="10.0" styleClass="top-status-bar">
                <padding>
                    <Insets bottom="10.0" left="34.0" right="34.0" top="24.0" />
                </padding>

                <Region maxHeight="8.0" maxWidth="8.0" minHeight="8.0" minWidth="8.0" prefHeight="8.0" prefWidth="8.0" styleClass="status-dot" />
                <Label styleClass="status-label" text="FLEET COMMAND // SECTOR 07" />
                <Region HBox.hgrow="ALWAYS" />
                <Label styleClass="online-label" text="●  SYSTEM ONLINE" />
            </HBox>
        </top>

        <center>
            <StackPane alignment="CENTER">
                <padding>
                    <Insets bottom="12.0" left="32.0" right="32.0" top="8.0" />
                </padding>

                <VBox alignment="CENTER" maxWidth="570.0" spacing="22.0">
                    <VBox alignment="CENTER" spacing="5.0" styleClass="title-block">
                        <Label styleClass="eyebrow" text="DEEP SPACE FLEET COMMAND" />
                        <Label styleClass="game-title" text="NAVAL BATTLE" />
                        <HBox alignment="CENTER" spacing="10.0">
                            <Region prefHeight="1.0" prefWidth="82.0" styleClass="title-line, title-line-left" />
                            <Region maxHeight="6.0" maxWidth="6.0" minHeight="6.0" minWidth="6.0" prefHeight="6.0" prefWidth="6.0" styleClass="title-diamond" />
                            <Region prefHeight="1.0" prefWidth="82.0" styleClass="title-line, title-line-right" />
                        </HBox>
                        <Label styleClass="tagline" text="COMMAND THE VOID. OUTTHINK THE ENEMY." />
                    </VBox>

                    <VBox alignment="CENTER_LEFT" maxWidth="510.0" spacing="12.0" styleClass="command-panel">
                        <HBox alignment="CENTER_LEFT" spacing="8.0">
                            <Label styleClass="step-number" text="01" />
                            <Label styleClass="field-label" text="IDENTIFY YOUR COMMANDER" />
                            <Region HBox.hgrow="ALWAYS" />
                            <Label styleClass="required-label" text="REQUIRED" />
                        </HBox>

                        <TextField fx:id="playerNameField" maxWidth="1.7976931348623157E308" prefHeight="52.0" promptText="ENTER COMMANDER NAME" styleClass="commander-field" />

                        <Label styleClass="field-hint" text="Your callsign will appear in the tactical combat log." wrapText="true" />

                        <Region prefHeight="3.0" />

                        <Button fx:id="startGameButton" defaultButton="true" maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#handleStartGame" prefHeight="56.0" styleClass="action-button, start-button" text="START NEW GAME" />

                        <Button fx:id="loadGameButton" disable="true" maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#handleLoadGame" prefHeight="50.0" styleClass="action-button, load-button" text="LOAD GAME" />

                        <HBox alignment="CENTER" maxWidth="1.7976931348623157E308" spacing="7.0" styleClass="save-status">
                            <Region maxHeight="5.0" maxWidth="5.0" minHeight="5.0" minWidth="5.0" prefHeight="5.0" prefWidth="5.0" styleClass="save-status-dot" />
                            <Label fx:id="statusLabel" styleClass="save-status-label" text="NO SAVED CAMPAIGN DETECTED" />
                        </HBox>
                    </VBox>
                </VBox>
            </StackPane>
        </center>

        <bottom>
            <HBox alignment="CENTER" spacing="12.0" styleClass="footer-bar">
                <padding>
                    <Insets bottom="22.0" left="34.0" right="34.0" top="12.0" />
                </padding>
                <Region prefHeight="1.0" prefWidth="34.0" styleClass="footer-line" />
                <Label styleClass="footer-label" text="TACTICAL NETWORK" />
                <Label styleClass="footer-glyph" text="◆" />
                <Label styleClass="footer-label" text="ENCRYPTED CHANNEL" />
                <Region prefHeight="1.0" prefWidth="34.0" styleClass="footer-line" />
            </HBox>
        </bottom>
    </BorderPane>
</StackPane>
