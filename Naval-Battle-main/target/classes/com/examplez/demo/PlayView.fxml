<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<BorderPane maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity"
            prefHeight="600.0" prefWidth="920.0"
            style="-fx-background-color: #0b2545;"
            xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="Controller.PlayController">

    <top>
        <VBox alignment="CENTER" spacing="4.0" BorderPane.alignment="CENTER">
            <padding>
                <Insets bottom="16.0" top="20.0" />
            </padding>
            <Label text="BATALLA NAVAL" textFill="WHITE">
                <font>
                    <javafx.scene.text.Font name="System Bold" size="26.0" />
                </font>
            </Label>
            <Label fx:id="turnLabel" text="Turno: jugador" textFill="#9fb8d9">
                <font>
                    <javafx.scene.text.Font size="13.0" />
                </font>
            </Label>
        </VBox>
    </top>

    <center>
        <HBox alignment="CENTER" spacing="40.0" BorderPane.alignment="CENTER">
            <padding>
                <Insets bottom="30.0" left="20.0" right="20.0" top="10.0" />
            </padding>

            <VBox alignment="CENTER" spacing="10.0">
                <Label text="Tablero principal (ataca aquí)" textFill="WHITE">
                    <font>
                        <javafx.scene.text.Font name="System Bold" size="14.0" />
                    </font>
                </Label>
                <GridPane fx:id="mainBoardGrid" alignment="CENTER" hgap="2.0" vgap="2.0"
                          style="-fx-background-color: #123a63; -fx-background-radius: 8; -fx-padding: 10;" />
            </VBox>

            <VBox alignment="CENTER" spacing="10.0">
                <Label text="Tu tablero (observación)" textFill="WHITE">
                    <font>
                        <javafx.scene.text.Font name="System Bold" size="14.0" />
                    </font>
                </Label>
                <GridPane fx:id="positionBoardGrid" alignment="CENTER" hgap="2.0" vgap="2.0"
                          style="-fx-background-color: #123a63; -fx-background-radius: 8; -fx-padding: 10; -fx-opacity: 0.9;" />
            </VBox>

        </HBox>
    </center>

</BorderPane>
